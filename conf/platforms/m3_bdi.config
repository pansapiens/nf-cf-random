/*
 * Monash M3 / MASSIVE HPC (example overlay).
 */

params.slurm_account = false

def account_opt = (params.slurm_account ? " --account=${params.slurm_account} " : '')

executor {
    $slurm {
        queueSize         = 200
        pollInterval      = '30 sec'
        queueStatInterval = '10m'
    }
}

process {
    executor      = 'slurm'
    stageInMode   = 'symlink'
    errorStrategy = 'retry'
    maxRetries    = 1
    cache         = 'lenient'

    withName: CF_RANDOM {
        clusterOptions = "--gres=gpu:1 --partition=gpu,fit,bdi --qos=irq ${account_opt}"
        time           = 12.hours
        accelerator    = 1
        memory         = '32 GB'
        cpus           = 8
    }
}

apptainer {
    enabled    = true
    autoMounts = true
    runOptions = "--nv --cleanenv --env PYTHONNOUSERSITE=1 -B \$HOME -B /scratch2 -B /fs04"
}
